{
  "name": "@prompt-optimizer/demo-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean": "rm -rf .next",
    "dev": "sh -c 'rm -rf .next && WATCHPACK_POLLING=true next dev -p ${PORT:-3001}'",
    "build": "sh -c 'rm -rf .next && next build'",
    "start": "sh -c 'next start -p ${PORT:-3001}'",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@prompt-optimizer/shared": "0.1.0",
    "@supabase/supabase-js": "^2.103.3",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.17",
    "typescript": "^5.6.3"
  }
}
